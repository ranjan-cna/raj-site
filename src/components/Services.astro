<style>
  /* ── Section header fade-up on scroll ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .section-header {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }

  .section-header.visible {
    animation: fadeUp 0.6s ease forwards;
  }

  /* ── Cards: start hidden, animate in via JS ── */
  .service-card {
    opacity: 0;
    transform: translateY(24px);
    transition:
        opacity 0.5s ease,
        transform 0.5s ease,
        box-shadow 0.25s ease;
  }

  .service-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Card hover: lift + left accent border ── */
  .service-card:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  .service-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 16px;
    bottom: 16px;
    width: 3px;
    background: oklch(var(--p));
    border-radius: 0 2px 2px 0;
    opacity: 0;
    transition: opacity 0.25s ease, top 0.25s ease, bottom 0.25s ease;
  }

  .service-card:hover::before {
    opacity: 1;
    top: 8px;
    bottom: 8px;
  }

  /* Card needs relative for the ::before to work */
  .service-card {
    position: relative;
    overflow: hidden;
  }

  /* ── Icon bounce on card hover ── */
  .card-icon {
    font-size: 1.6rem;
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .service-card:hover .card-icon {
    transform: scale(1.2) rotate(-5deg);
  }

  /* ── List items stagger on hover ── */
  .service-card ul li {
    transition: padding-left 0.2s ease, color 0.2s ease;
  }

  .service-card:hover ul li {
    padding-left: 6px;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .service-card,
    .section-header,
    .card-icon,
    .service-card ul li {
      animation: none;
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
  );

  // Stagger cards as they scroll into view
  document.querySelectorAll('.service-card').forEach((card, i) => {
    (card as HTMLElement).style.transitionDelay = `${i * 80}ms`;
    observer.observe(card);
  });

  document.querySelectorAll('.section-header').forEach((el) => {
    observer.observe(el);
  });
</script>