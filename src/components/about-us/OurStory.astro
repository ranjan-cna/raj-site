<style>
  .story-section {
    --item-transition: 0.22s ease;
  }

  .story-section .fade-in-up {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .story-section.visible .fade-in-up:nth-child(1) { opacity: 1; transform: translateY(0); transition-delay: 0s; }
  .story-section.visible .fade-in-up:nth-child(2) { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .story-section.visible .fade-in-up:nth-child(3) { opacity: 1; transform: translateY(0); transition-delay: 0.2s; }
  .story-section.visible .fade-in-up:nth-child(4) { opacity: 1; transform: translateY(0); transition-delay: 0.28s; }

  .story-img-wrap {
    overflow: hidden;
    border-radius: var(--rounded-box, 1rem);
  }

  .story-img-wrap img {
    transition: transform 0.4s ease;
  }

  .story-img-wrap:hover img {
    transform: scale(1.03);
  }

  @media (prefers-reduced-motion: reduce) {
    .story-section .fade-in-up,
    .story-img-wrap img {
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<section class="story-section py-20 px-4 bg-base-100">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Story Text -->
      <div class="flex flex-col gap-6">

        <!-- Header -->
        <div class="fade-in-up">
          <p class="text-xs font-semibold tracking-widest text-primary uppercase mb-3">Our Story</p>
          <h2 class="text-4xl font-bold mb-4">Where It All Began</h2>
        </div>

        <!-- Story Paragraphs -->
        <div class="fade-in-up flex flex-col gap-5 text-base-content/70 text-[15px] leading-relaxed">
          <p>
            For over two decades, I built my career at the heart of global finance. As a Manager of Record-to-Report at Genpact — one of the world's leading professional services firms — I led complex financial operations for large-scale clients, developing a deep mastery of accounting, reporting, and financial process management.
          </p>
          <p>
            After years of working within large corporations, I saw a clear gap in the market — small and mid-sized businesses were struggling with the same financial challenges that big enterprises solved with entire departments. The expertise existed. The access didn't.
          </p>
          <p>
            That's why I founded Ranjan Cost & Accounting. To bring enterprise-grade financial expertise to businesses of every size — without the overhead of an in-house team. What started as one person's vision is now a dedicated practice built on precision, confidentiality, and a genuine commitment to every client's financial success.
          </p>
        </div>

        <!-- Founder Signature -->
        <div class="fade-in-up flex items-center gap-4 pt-2">
          <div class="w-12 h-[2px] bg-primary"></div>
          <p class="text-sm font-semibold">Founder, Ranjan Cost & Accounting</p>
        </div>

      </div>

      <!-- Right: Image -->
      <div class="fade-in-up hidden lg:flex items-center justify-center">
        <div class="story-img-wrap w-full shadow-md">
          <img
              alt="Our story"
              class="object-cover w-full h-[560px]"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const section = document.querySelector('.story-section');
  if (section) {
    const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            section.classList.add('visible');
            observer.disconnect();
          }
        },
        { threshold: 0.15 }
    );
    observer.observe(section);
  }
</script>