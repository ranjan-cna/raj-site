---
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import Pricing from '../components/pricing/Pricing.astro'
import Layout from '../layouts/Layout.astro'
---

<Layout>
    <Navbar />

    <section class="bg-gray-50 px-6 py-16">
        <div class="text-center mb-12">
      <span class="inline-block text-xs font-medium tracking-widest uppercase text-emerald-700 bg-emerald-50 px-4 py-1.5 rounded-full mb-4">
        Our services
      </span>
            <h1 class="font-serif text-4xl font-normal mb-2">Simple, transparent pricing</h1>
            <p class="text-gray-500 text-sm max-w-md mx-auto">
                Everything your business needs, billed by the hour with no hidden fees.
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto">
            <Pricing title="Financial Accounting" price={50} selectOption="Financial Accounting">
                <li>Bookkeeping & Ledger Maintenance</li>
                <li>Financial Statement Preparation</li>
                <li>Bank Reconciliation</li>
                <li>Accounts Payable & Receivable Management</li>
                <li>Payroll Processing</li>
                <li>Tax Preparation & Compliance</li>
                <li>Audit Support</li>
            </Pricing>

            <Pricing title="Cost Accounting" price={50} selectOption="Cost Accounting">
                <li>Cost Sheet Preparation</li>
                <li>Standard Costing & Variance Analysis</li>
                <li>Job & Process Costing</li>
                <li>Marginal Costing & CVP Analysis</li>
                <li>Inventory Valuation</li>
                <li>Budget Preparation & Control</li>
                <li>Profitability Analysis</li>
            </Pricing>

            <Pricing title="GST Services" price={50} selectOption="GST">
                <li>GST Registration</li>
                <li>GST Return Filing</li>
                <li>Input Tax Credit (ITC) Reconciliation</li>
                <li>GST Audit & Annual Return</li>
                <li>E-Invoicing & E-Way Bill Compliance</li>
                <li>GST Notice & Litigation Support</li>
                <li>GST Health Check</li>
            </Pricing>

            <Pricing title="Income Tax" price={50} selectOption="Income Tax">
                <li>Income Tax Return Filing</li>
                <li>Tax Planning & Advisory</li>
                <li>TDS Compliance & Return Filing</li>
                <li>Advance Tax Computation</li>
                <li>Income Tax Notice Handling</li>
                <li>Form 15CA/15CB Assistance</li>
                <li>Tax Audit Support</li>
            </Pricing>

            <Pricing title="MIS Reporting" price={50} selectOption="MIS Reporting">
                <li>Monthly MIS Report Preparation</li>
                <li>Cash Flow Statements & Projections</li>
                <li>Budget vs Actual Analysis</li>
                <li>KPI Dashboards & Scorecards</li>
                <li>Debtor & Creditor Aging Reports</li>
                <li>Profitability & Cost Center Reports</li>
                <li>Custom Management Reports</li>
            </Pricing>
        </div>
    </section>

    <Footer />
</Layout>